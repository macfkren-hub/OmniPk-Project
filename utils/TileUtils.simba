{------------------------------------------------------------------------------}
{ GetDirectionVector - Get normalized direction from one tile to another       }
{------------------------------------------------------------------------------}
function GetDirectionVector(FromTile, ToTile: TPoint): TPoint;
var
  DX, DY: Integer;
begin
  DX := ToTile.X - FromTile.X;
  DY := ToTile.Y - FromTile.Y;
  
  // Normalize to -1, 0, or 1
  if DX > 0 then Result.X := 1
  else if DX < 0 then Result.X := -1
  else Result.X := 0;
  
  if DY > 0 then Result.Y := 1
  else if DY < 0 then Result.Y := -1
  else Result.Y := 0;
end;

{------------------------------------------------------------------------------}
{ OffsetTile - Apply offset to a tile                                          }
{------------------------------------------------------------------------------}
function OffsetTile(Tile: TPoint; OffsetX, OffsetY: Integer): TPoint;
begin
  Result.X := Tile.X + OffsetX;
  Result.Y := Tile.Y + OffsetY;
end;
